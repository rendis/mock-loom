# Server
MOCK_LOOM_SERVER_PORT=8080

# SQLite
MOCK_LOOM_DB_DSN=file:mock-loom.db?_pragma=foreign_keys(1)
MOCK_LOOM_MIGRATIONS_DIR=db/migrations

# OIDC provider (preferred)
MOCK_LOOM_AUTH_NAME=keycloak
MOCK_LOOM_AUTH_DISCOVERY_URL=https://auth.example.com/realms/mockloom
MOCK_LOOM_AUTH_CLIENT_ID=mock-loom-web
MOCK_LOOM_AUTH_AUDIENCE=mock-loom-web
MOCK_LOOM_AUTH_SCOPES=openid profile email

# Optional explicit endpoints (fallback when discovery not used)
# MOCK_LOOM_AUTH_ISSUER=https://auth.example.com/realms/mockloom
# MOCK_LOOM_AUTH_JWKS_URL=https://auth.example.com/realms/mockloom/protocol/openid-connect/certs
# MOCK_LOOM_AUTH_AUTHORIZATION_ENDPOINT=https://auth.example.com/realms/mockloom/protocol/openid-connect/auth
# MOCK_LOOM_AUTH_TOKEN_ENDPOINT=https://auth.example.com/realms/mockloom/protocol/openid-connect/token
# MOCK_LOOM_AUTH_USERINFO_ENDPOINT=https://auth.example.com/realms/mockloom/protocol/openid-connect/userinfo
# MOCK_LOOM_AUTH_END_SESSION_ENDPOINT=https://auth.example.com/realms/mockloom/protocol/openid-connect/logout

# Bootstrap first login
MOCK_LOOM_BOOTSTRAP_ENABLED=true
MOCK_LOOM_BOOTSTRAP_ALLOWED_EMAILS=admin@example.com
MOCK_LOOM_BOOTSTRAP_ALLOWED_DOMAINS=example.com

# Dev fallback (only local/dev)
MOCK_LOOM_DUMMY_AUTH_ENABLED=true
MOCK_LOOM_DUMMY_AUTH_EMAIL=admin@mockloom.local
MOCK_LOOM_DUMMY_AUTH_SUBJECT=dummy-admin

# Import pipeline limits and converter CLIs
MOCK_LOOM_IMPORT_MAX_BYTES=5242880
MOCK_LOOM_IMPORT_TIMEOUT_SECONDS=15
MOCK_LOOM_IMPORT_MAX_ROUTES=500
MOCK_LOOM_IMPORT_POSTMAN_CLI_PATH=p2o
MOCK_LOOM_IMPORT_CURL_CLI_PATH=curlconverter

# Runtime YAML config (optional) + Data Sources env override
MOCK_LOOM_CONFIG_YAML=config.yaml
MOCK_LOOM_DATA_SOURCES_MAX_BYTES=10485760
